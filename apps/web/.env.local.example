# Copy to apps/web/.env.local for local development.
# .env.local is gitignored; never commit real values.

# Upstream FastAPI origin. Use the SAME tunnel URL as
# GEO_NYC_PUBLIC_BASE_URL on the API host.
#
# Local API on the same machine:
#   NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
#
# Tunnel (ngrok-free.dev / .app, cloudflared, tailscale):
NEXT_PUBLIC_API_BASE_URL=https://miah-sleetiest-azalea.ngrok-free.dev

# (Optional) Pin the 3D dock to a specific successful run id.
# When unset, the newest run with a mesh on disk is used.
# NEXT_PUBLIC_MESH_RUN_ID=r_20260101000000_abcdef12

# (Optional) Override the GLB URL entirely (highest priority).
# NEXT_PUBLIC_GLTF_URL=https://example.com/path/to/model.glb
