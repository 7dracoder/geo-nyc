# =====================================================================
# geo-nyc backend environment variables
#
# Copy to .env (which is gitignored) and adjust as needed.
# All variables are prefixed GEO_NYC_ so they don't collide with
# unrelated tooling. They are loaded by `geo_nyc.config.Settings`.
# =====================================================================

# --- LLM provider -----------------------------------------------------
# Only "ollama" is supported. Cloud providers are intentionally absent.
GEO_NYC_LLM_PROVIDER=ollama

# Ollama server URL. Default Ollama listens on 11434.
GEO_NYC_OLLAMA_BASE_URL=http://localhost:11434

# Default chat model used for extraction. Pull it once via:
#   ollama pull llama3.1:8b
GEO_NYC_OLLAMA_MODEL=llama3.1:8b

# Optional override for the relevance / DSL repair calls (defaults to OLLAMA_MODEL)
# GEO_NYC_OLLAMA_FAST_MODEL=llama3.1:8b

# Sampling parameters for the extraction LLM call.
GEO_NYC_LLM_TEMPERATURE=0.2
GEO_NYC_LLM_MAX_TOKENS=4096

# Generation timeout per Ollama call, seconds.
GEO_NYC_LLM_TIMEOUT_SECONDS=120

# Number of automatic repair iterations after a failed JSON / DSL validation.
GEO_NYC_LLM_MAX_REPAIR_ATTEMPTS=2

# --- API server -------------------------------------------------------
GEO_NYC_API_HOST=127.0.0.1
GEO_NYC_API_PORT=8000
GEO_NYC_DEBUG=false

# Comma-separated list of CORS origins allowed by the FastAPI app.
# Add the Vercel production URL here for the live frontend.
GEO_NYC_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://geo-nyc.vercel.app

# Optional regex matched against the Origin header. Useful for Vercel
# preview deployments whose URLs change every push (e.g.
# https://geo-nyc-git-feature-foo-username.vercel.app).
GEO_NYC_CORS_ORIGIN_REGEX=^https://geo-nyc(-[a-z0-9-]+)?\.vercel\.app$

# Public base URL where /static/exports is reachable from a browser.
# Used to stamp absolute mesh / field URLs into every run manifest.
#
# Local dev:    http://localhost:8000
# Demo with Vercel-hosted frontend: tunnel your laptop with one of
#   ngrok http 8000              -> https://<random>.ngrok-free.app
#   cloudflared tunnel --url http://localhost:8000
# and paste the resulting https URL here, then restart the backend.
GEO_NYC_PUBLIC_BASE_URL=http://localhost:8000

# --- Storage roots ----------------------------------------------------
# All paths are resolved relative to the repository root if relative.
GEO_NYC_DATA_DIR=./data
GEO_NYC_DOCUMENTS_RAW_DIR=./data/documents/raw
GEO_NYC_DOCUMENTS_EXTRACTED_DIR=./data/documents/extracted
GEO_NYC_RUNS_DIR=./data/runs
GEO_NYC_EXPORTS_DIR=./data/exports
GEO_NYC_FIELDS_DIR=./data/fields
GEO_NYC_CACHE_DIR=./data/cache

# --- Pipeline toggles -------------------------------------------------
# When true, /api/run uses on-disk fixtures instead of running the LLM
# and GemPy. Useful for the demo and for offline development.
GEO_NYC_USE_FIXTURES=true

# When true, the GemPy modeling path is enabled. When false (default),
# the run service uses the trimesh-only fallback mesh builder.
GEO_NYC_ENABLE_GEMPY=false

# --- Logging ----------------------------------------------------------
# One of: DEBUG, INFO, WARNING, ERROR
GEO_NYC_LOG_LEVEL=INFO
